# Database configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_sovereign_secure
POSTGRES_DB=sovereign_talent
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis / Queue configuration
REDIS_URL=redis://redis:6379/0

# AI Layer Configurations
# LLM_PROVIDER options: 'ollama', 'gemini', 'openai'
LLM_PROVIDER=ollama

# Ollama settings (Local Sovereign LLM running on host machine)
OLLAMA_API_BASE=http://host.docker.internal:11434
OLLAMA_MODEL=llama3

# Gemini configuration
GEMINI_MODEL=gemini-2.5-pro
GEMINI_API_KEY=

# Fallback hosted providers keys (needed if LLM_PROVIDER is set to openai)
OPENAI_API_KEY=
